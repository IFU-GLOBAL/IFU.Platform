{
  "name": "ifu-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:static": "node scripts/sync-static-site.mjs",
    "predev": "node scripts/sync-static-site.mjs && prisma generate",
    "dev": "next dev",
    "prebuild": "node scripts/sync-static-site.mjs && prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "auth:audit": "node scripts/audit-auth-config.mjs",
    "roles:audit": "tsx scripts/audit-role-catalog.ts",
    "agrisphere:audit": "tsx scripts/audit-agrisphere-data.ts",
    "agrisphere:index": "tsx scripts/index-agrisphere-search.ts",
    "test:agrisphere": "tsx --test tests/agrisphere-data.test.ts",
    "review:audit": "node scripts/review-audit.mjs",
    "review:smoke": "node scripts/review-smoke.mjs",
    "db:generate": "prisma generate",
    "db:local": "prisma dev -d --name ifu-preview",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "invitations:import": "tsx scripts/import-invitations.ts",
    "maintenance:referral-cleanup": "node scripts/run-referral-cleanup.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1085.0",
    "@aws-sdk/client-sesv2": "^3.1077.0",
    "@aws-sdk/credential-provider-node": "^3.972.70",
    "@opensearch-project/opensearch": "^3.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "openid-client": "^5.7.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
