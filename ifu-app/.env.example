DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ifu?schema=public"

# Optional Sprint 1.5 managed search and distributed cache services.
# OpenSearch uses AWS SigV4 when OPENSEARCH_REGION is set and basic auth when
# OPENSEARCH_USERNAME is set. Use OPENSEARCH_SERVICE="aoss" for Serverless.
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX="ifu-agrisphere-discovery-v1"
OPENSEARCH_REGION="us-east-1"
OPENSEARCH_SERVICE="es"
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
REDIS_URL=

# Cognito auth. Do not commit real secrets.
APP_BASE_URL="http://localhost:3000"
AUTH_SESSION_SECRET=
COGNITO_REGION="us-east-1"
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI="http://localhost:3000/api/auth/callback"
COGNITO_LOGOUT_URI="http://localhost:3000/"
COGNITO_SCOPES="openid email"

# Example: COGNITO_DOMAIN="https://your-domain.auth.us-east-1.amazoncognito.com"

# Public aliases retained for compatibility with earlier Milestone 5 placeholders.
NEXT_PUBLIC_COGNITO_REGION=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

SES_REGION="us-east-1"
SES_FROM_EMAIL="preview@internationalfarmunion.com"
SES_REPLY_TO_EMAIL="info@internationalfarmunion.com"

# Used by /api/maintenance/referral-cleanup and cron runners.
MAINTENANCE_SECRET=
CRON_SECRET=
