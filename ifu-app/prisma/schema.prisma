generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccessStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  SUSPENDED
}

enum DashboardItemType {
  OPPORTUNITY
  TRAINING
  FUNDING
  MARKETPLACE
  EXPERT
  COMMUNITY
  MAP_COUNTRY
  DOCUMENT
  MESSAGE
  APPLICATION
  ECOSYSTEM
  RESOURCE
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  summary   String
  sortOrder Int
  isActive  Boolean  @default(true)
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id                  String                   @id @default(cuid())
  slug                String                   @unique
  title               String
  summary             String
  pathway             String
  level               String?
  description         String?
  keywords            String[]                 @default([])
  isActive            Boolean                  @default(true)
  sortOrder           Int
  categoryId          String
  category            RoleCategory             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  submissions         PreviewSubmissionRole[]
  selectedBy          UserSelectedRole[]
  previewApplications PreviewApplicationRole[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([categoryId])
}

model User {
  id               String             @id @default(cuid())
  cognitoId        String?            @unique
  email            String             @unique
  fullName         String
  accessStatus     AccessStatus       @default(PENDING)
  profile          UserProfile?
  selectedRoles    UserSelectedRole[]
  workspaceItems   WorkspaceItem[]
  bookmarks        Bookmark[]
  applications     Application[]
  documents        Document[]
  messagesSent     Message[]          @relation("sentMessages")
  messagesReceived Message[]          @relation("receivedMessages")
  activityLogs     ActivityLog[]
  geoEvents        GeoEvent[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  primaryRoleId     String?
  primaryCategoryId String?
  country           String?
  stateProvince     String?
  city              String?
  region            String?
  timezone          String?
  localTimeLabel    String?
  latitude          Float?
  longitude         Float?
  organization      String?
  phone             String?
  profileCompletion Int      @default(0)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([primaryRoleId])
  @@index([primaryCategoryId])
}

model UserSelectedRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  isPrimary Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

model PreviewSubmission {
  id                             String                  @id @default(cuid())
  firstName                      String
  lastName                       String
  email                          String
  phone                          String?
  country                        String?
  organization                   String?
  roleOrTitle                    String?
  selectedRoleSlugs              String[]
  leadershipInterest             String?
  contributionInterests          String[]
  referralSource                 String?
  referralDetail                 String?
  recommendedContactName         String?
  recommendedContactEmail        String?
  recommendedContactRelationship String?
  message                        String?
  emailStatus                    String                  @default("pending")
  emailMessageId                 String?
  emailError                     String?
  roles                          PreviewSubmissionRole[]
  recommendedContacts            RecommendedContact[]
  referralSources                ReferralSource[]
  geoEvents                      GeoEvent[]
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
}

model PreviewSubmissionRole {
  id           String            @id @default(cuid())
  submissionId String
  roleId       String
  submission   PreviewSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  role         Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([submissionId, roleId])
  @@index([roleId])
}

model PreviewApplication {
  id                  String                   @id @default(cuid())
  fullName            String
  email               String
  phone               String?
  country             String?
  organization        String?
  message             String?
  howHeard            String[]                 @default([])
  motivation          String[]                 @default([])
  expectedShareCount  String?
  referralUrl         String?
  utmSource           String?
  utmCampaign         String?
  utmMedium           String?
  cityDetected        String?
  countryDetected     String?
  selectedRoles       PreviewApplicationRole[]
  recommendedContacts RecommendedContact[]
  referralSources     ReferralSource[]
  geoEvents           GeoEvent[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model PreviewApplicationRole {
  id            String             @id @default(cuid())
  applicationId String
  roleId        String
  application   PreviewApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  role          Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([applicationId, roleId])
  @@index([roleId])
}

model RecommendedContact {
  id                   String              @id @default(cuid())
  previewSubmissionId  String?
  previewApplicationId String?
  name                 String
  organization         String?
  email                String?
  relationship         String?
  reason               String?
  previewSubmission    PreviewSubmission?  @relation(fields: [previewSubmissionId], references: [id], onDelete: Cascade)
  previewApplication   PreviewApplication? @relation(fields: [previewApplicationId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())

  @@index([previewSubmissionId])
  @@index([previewApplicationId])
}

model ReferralSource {
  id                   String              @id @default(cuid())
  previewSubmissionId  String?
  previewApplicationId String?
  source               String
  detail               String?
  referrerUrl          String?
  utmSource            String?
  utmCampaign          String?
  utmMedium            String?
  metadata             Json?
  previewSubmission    PreviewSubmission?  @relation(fields: [previewSubmissionId], references: [id], onDelete: Cascade)
  previewApplication   PreviewApplication? @relation(fields: [previewApplicationId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())

  @@index([previewSubmissionId])
  @@index([previewApplicationId])
}

model DashboardItem {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  type           DashboardItemType
  category       String?
  summary        String?
  description    String?
  country        String?
  roleTargets    String[]          @default([])
  actionLabel    String?
  imageUrl       String?
  metadata       Json?
  workspaceItems WorkspaceItem[]
  bookmarks      Bookmark[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model WorkspaceItem {
  id              String            @id @default(cuid())
  userId          String
  dashboardItemId String?
  title           String
  itemType        DashboardItemType
  status          String            @default("ACTIVE")
  progress        Int               @default(0)
  dueDate         DateTime?
  notes           String?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardItem   DashboardItem?    @relation(fields: [dashboardItemId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([dashboardItemId])
}

model Bookmark {
  id              String            @id @default(cuid())
  userId          String
  dashboardItemId String?
  title           String
  itemType        DashboardItemType
  notes           String?
  reminderDate    DateTime?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardItem   DashboardItem?    @relation(fields: [dashboardItemId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([dashboardItemId])
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  title     String
  type      String
  status    ApplicationStatus @default(DRAFT)
  step      String?
  metadata  Json?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId])
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  fileType  String?
  s3Key     String
  category  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  subject    String?
  body       String
  readAt     DateTime?
  sender     User      @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User      @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([senderId])
  @@index([receiverId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}

model GeoEvent {
  id                   String              @id @default(cuid())
  userId               String?
  previewSubmissionId  String?
  previewApplicationId String?
  city                 String?
  region               String?
  country              String?
  timezone             String?
  latitude             Float?
  longitude            Float?
  source               String?
  consentStatus        String?
  ipAddress            String?
  userAgent            String?
  metadata             Json?
  user                 User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  previewSubmission    PreviewSubmission?  @relation(fields: [previewSubmissionId], references: [id], onDelete: Cascade)
  previewApplication   PreviewApplication? @relation(fields: [previewApplicationId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())

  @@index([userId])
  @@index([previewSubmissionId])
  @@index([previewApplicationId])
}
