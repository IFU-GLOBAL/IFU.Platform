generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccessStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  SUSPENDED
}

enum DashboardItemType {
  OPPORTUNITY
  TRAINING
  FUNDING
  MARKETPLACE
  EXPERT
  COMMUNITY
  MAP_COUNTRY
  DOCUMENT
  MESSAGE
  APPLICATION
  ECOSYSTEM
  RESOURCE
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

enum InvitationStatus {
  PENDING
  OPENED
  REGISTERED
  EXPIRED
  INVALIDATED
}

enum AcquisitionSource {
  ORGANIC
  INVITATION
}

enum AgriSphereActivityLevel {
  HIGH
  MEDIUM
  EMERGING
  LOW
  NO_DATA
}

enum AgriSphereOpportunityStatus {
  ACTIVE
  CLOSED
  DRAFT
}

enum AgriSphereEventFormat {
  VIRTUAL
  IN_PERSON
  HYBRID
}

enum AgriSpherePartnerTier {
  INSTITUTIONAL
  STRATEGIC
  COMMUNITY
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  summary   String
  sortOrder Int
  isActive  Boolean  @default(true)
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id                  String                   @id @default(cuid())
  slug                String                   @unique
  title               String
  summary             String
  pathway             String
  level               String?
  description         String?
  keywords            String[]                 @default([])
  isActive            Boolean                  @default(true)
  sortOrder           Int
  categoryId          String
  category            RoleCategory             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  submissions         PreviewSubmissionRole[]
  selectedBy          UserSelectedRole[]
  previewApplications PreviewApplicationRole[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([categoryId])
}

model User {
  id                             String                  @id @default(cuid())
  cognitoId                      String?                 @unique
  email                          String                  @unique
  fullName                       String
  firstName                      String?
  lastName                       String?
  preferredDisplayName           String?
  termsAccepted                  Boolean                 @default(false)
  termsAcceptedAt                DateTime?
  marketingOptIn                 Boolean                 @default(false)
  marketingOptInAt               DateTime?
  ageConfirmedAt                 DateTime?
  accessStatus                   AccessStatus            @default(PENDING)
  profile                        UserProfile?
  selectedRoles                  UserSelectedRole[]
  workspaceItems                 WorkspaceItem[]
  bookmarks                      Bookmark[]
  applications                   Application[]
  documents                      Document[]
  messagesSent                   Message[]               @relation("sentMessages")
  messagesReceived               Message[]               @relation("receivedMessages")
  activityLogs                   ActivityLog[]
  geoEvents                      GeoEvent[]
  acquisition                    UserAcquisition?
  registeredInvitations          Invitation[]
  agriSphereOpportunitiesCreated AgriSphereOpportunity[] @relation("AgriSphereOpportunityCreatedBy")
  agriSphereSavedItems           AgriSphereSavedItem[]
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
}

model Invitation {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String?
  email            String?
  normalizedEmail  String?
  phone            String?
  normalizedPhone  String?
  country          String?
  suggestedRole    String?
  invitedBy        String?
  channel          String            @default("copy_link")
  status           InvitationStatus  @default(PENDING)
  expiresAt        DateTime
  openedAt         DateTime?
  registeredAt     DateTime?
  registeredUserId String?
  metadata         Json?
  registeredUser   User?             @relation(fields: [registeredUserId], references: [id], onDelete: SetNull)
  acquisitions     UserAcquisition[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([normalizedEmail, status])
  @@index([normalizedPhone, status])
  @@index([expiresAt])
  @@index([registeredUserId])
}

model UserAcquisition {
  id                 String            @id @default(cuid())
  userId             String            @unique
  source             AcquisitionSource @default(ORGANIC)
  invitationId       String?
  invitedBy          String?
  inviteChannel      String?
  selfReportedSource String?
  selfReportedDetail String?
  utmSource          String?
  utmCampaign        String?
  utmMedium          String?
  firstTouchUrl      String?
  metadata           Json?
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitation         Invitation?       @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([source])
  @@index([invitationId])
  @@index([inviteChannel])
  @@index([utmSource, utmCampaign])
}

model UserProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  primaryRoleId         String?
  primaryCategoryId     String?
  country               String?
  stateProvince         String?
  city                  String?
  region                String?
  timezone              String?
  localTimeLabel        String?
  latitude              Float?
  longitude             Float?
  organization          String?
  phone                 String?
  preferredLanguage     String?
  interests             String[] @default([])
  primaryCropsLivestock String[] @default([])
  farmSizeBand          String?
  goals                 String?
  profileCompletion     Int      @default(0)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([primaryRoleId])
  @@index([primaryCategoryId])
}

model UserSelectedRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  isPrimary Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
}

model PreviewSubmission {
  id                             String                  @id @default(cuid())
  firstName                      String
  lastName                       String
  email                          String
  phone                          String?
  country                        String?
  organization                   String?
  roleOrTitle                    String?
  selectedRoleSlugs              String[]
  leadershipInterest             String?
  contributionInterests          String[]
  referralSource                 String?
  referralDetail                 String?
  recommendedContactName         String?
  recommendedContactEmail        String?
  recommendedContactRelationship String?
  message                        String?
  privacyConsentAccepted         Boolean                 @default(false)
  privacyConsentAcceptedAt       DateTime?
  referralConsentAccepted        Boolean                 @default(false)
  referralConsentAcceptedAt      DateTime?
  emailStatus                    String                  @default("pending")
  emailMessageId                 String?
  emailError                     String?
  roles                          PreviewSubmissionRole[]
  recommendedContacts            RecommendedContact[]
  referralSources                ReferralSource[]
  geoEvents                      GeoEvent[]
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
}

model PreviewSubmissionRole {
  id           String            @id @default(cuid())
  submissionId String
  roleId       String
  submission   PreviewSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  role         Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([submissionId, roleId])
  @@index([roleId])
}

model PreviewApplication {
  id                  String                   @id @default(cuid())
  fullName            String
  email               String
  phone               String?
  country             String?
  organization        String?
  message             String?
  howHeard            String[]                 @default([])
  motivation          String[]                 @default([])
  expectedShareCount  String?
  referralUrl         String?
  utmSource           String?
  utmCampaign         String?
  utmMedium           String?
  cityDetected        String?
  countryDetected     String?
  selectedRoles       PreviewApplicationRole[]
  recommendedContacts RecommendedContact[]
  referralSources     ReferralSource[]
  geoEvents           GeoEvent[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model PreviewApplicationRole {
  id            String             @id @default(cuid())
  applicationId String
  roleId        String
  application   PreviewApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  role          Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([applicationId, roleId])
  @@index([roleId])
}

model RecommendedContact {
  id                     String              @id @default(cuid())
  previewSubmissionId    String?
  previewApplicationId   String?
  name                   String
  organization           String?
  email                  String?
  relationship           String?
  reason                 String?
  consentConfirmed       Boolean             @default(false)
  consentConfirmedAt     DateTime?
  oneTimeInviteStatus    String              @default("pending")
  oneTimeInviteMessageId String?
  oneTimeInviteError     String?
  oneTimeInviteSentAt    DateTime?
  deleteTokenHash        String?             @unique
  deleteTokenExpiresAt   DateTime?
  deleteAfter            DateTime?
  previewSubmission      PreviewSubmission?  @relation(fields: [previewSubmissionId], references: [id], onDelete: Cascade)
  previewApplication     PreviewApplication? @relation(fields: [previewApplicationId], references: [id], onDelete: Cascade)
  createdAt              DateTime            @default(now())

  @@index([previewSubmissionId])
  @@index([previewApplicationId])
}

model ReferralSource {
  id                   String              @id @default(cuid())
  previewSubmissionId  String?
  previewApplicationId String?
  source               String
  detail               String?
  referrerUrl          String?
  utmSource            String?
  utmCampaign          String?
  utmMedium            String?
  metadata             Json?
  previewSubmission    PreviewSubmission?  @relation(fields: [previewSubmissionId], references: [id], onDelete: Cascade)
  previewApplication   PreviewApplication? @relation(fields: [previewApplicationId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())

  @@index([previewSubmissionId])
  @@index([previewApplicationId])
}

model DashboardItem {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  type           DashboardItemType
  category       String?
  summary        String?
  description    String?
  country        String?
  roleTargets    String[]          @default([])
  actionLabel    String?
  imageUrl       String?
  metadata       Json?
  workspaceItems WorkspaceItem[]
  bookmarks      Bookmark[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model WorkspaceItem {
  id              String            @id @default(cuid())
  userId          String
  dashboardItemId String?
  title           String
  itemType        DashboardItemType
  status          String            @default("ACTIVE")
  progress        Int               @default(0)
  dueDate         DateTime?
  notes           String?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardItem   DashboardItem?    @relation(fields: [dashboardItemId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([dashboardItemId])
}

model Bookmark {
  id              String            @id @default(cuid())
  userId          String
  dashboardItemId String?
  title           String
  itemType        DashboardItemType
  notes           String?
  reminderDate    DateTime?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardItem   DashboardItem?    @relation(fields: [dashboardItemId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([dashboardItemId])
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  title     String
  type      String
  status    ApplicationStatus @default(DRAFT)
  step      String?
  metadata  Json?
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId])
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  fileType  String?
  s3Key     String
  category  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  subject    String?
  body       String
  readAt     DateTime?
  sender     User      @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User      @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([senderId])
  @@index([receiverId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}

model GeoEvent {
  id                   String              @id @default(cuid())
  userId               String?
  previewSubmissionId  String?
  previewApplicationId String?
  city                 String?
  region               String?
  country              String?
  timezone             String?
  latitude             Float?
  longitude            Float?
  source               String?
  consentStatus        String?
  ipAddress            String?
  userAgent            String?
  metadata             Json?
  user                 User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  previewSubmission    PreviewSubmission?  @relation(fields: [previewSubmissionId], references: [id], onDelete: Cascade)
  previewApplication   PreviewApplication? @relation(fields: [previewApplicationId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())

  @@index([userId])
  @@index([previewSubmissionId])
  @@index([previewApplicationId])
}

model AgriSphereContinent {
  id            String              @id @default(uuid()) @db.Uuid
  code          String              @unique
  name          String
  summary       String?
  priorityCrops String[]            @default([])
  countryCount  Int                 @default(0)
  countries     AgriSphereCountry[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model AgriSphereCountry {
  id               String                    @id @default(uuid()) @db.Uuid
  code             String                    @unique
  slug             String                    @unique
  name             String
  continentCode    String
  latitude         Float?
  longitude        Float?
  activityLevel    AgriSphereActivityLevel   @default(NO_DATA)
  primaryCrops     String[]                  @default([])
  opportunityCount Int                       @default(0)
  producerRank     Int?
  farmerCount      Int                       @default(0)
  partnerCount     Int                       @default(0)
  summary          String?
  continent        AgriSphereContinent       @relation(fields: [continentCode], references: [code], onDelete: Restrict)
  opportunities    AgriSphereOpportunity[]
  organizations    AgriSphereOrganization[]
  producers        AgriSphereProducer[]
  treatyLinks      AgriSphereTreatyCountry[]
  events           AgriSphereEvent[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([continentCode])
  @@index([activityLevel])
}

model AgriSphereOpportunity {
  id          String                      @id @default(uuid()) @db.Uuid
  slug        String                      @unique
  title       String
  description String
  category    String
  countryCode String?
  region      String?
  crops       String[]                    @default([])
  status      AgriSphereOpportunityStatus @default(ACTIVE)
  href        String?
  metadata    String[]                    @default([])
  createdById String?
  country     AgriSphereCountry?          @relation(fields: [countryCode], references: [code], onDelete: SetNull)
  createdBy   User?                       @relation("AgriSphereOpportunityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy     AgriSphereSavedItem[]
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([countryCode])
  @@index([createdById])
  @@index([status, countryCode, createdAt])
}

model AgriSphereSavedItem {
  userId        String
  opportunityId String                @db.Uuid
  savedAt       DateTime              @default(now())
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity   AgriSphereOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@id([userId, opportunityId])
  @@index([opportunityId])
}

model AgriSpherePersonaCluster {
  clusterId       Int      @id
  centroidVector  Json
  lastRefreshedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgriSphereOrganization {
  id          String             @id @default(uuid()) @db.Uuid
  slug        String             @unique
  name        String
  type        String
  description String?
  countryCode String?
  verified    Boolean            @default(false)
  href        String?
  metadata    String[]           @default([])
  country     AgriSphereCountry? @relation(fields: [countryCode], references: [code], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([countryCode])
  @@index([type])
}

model AgriSphereTreaty {
  id          String                    @id @default(uuid()) @db.Uuid
  slug        String                    @unique
  name        String
  type        String
  description String?
  href        String?
  metadata    String[]                  @default([])
  countries   AgriSphereTreatyCountry[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
}

model AgriSphereTreatyCountry {
  treatyId    String             @db.Uuid
  countryCode String
  treaty      AgriSphereTreaty  @relation(fields: [treatyId], references: [id], onDelete: Cascade)
  country     AgriSphereCountry @relation(fields: [countryCode], references: [code], onDelete: Cascade)

  @@id([treatyId, countryCode])
  @@index([countryCode])
}

model AgriSphereSector {
  id          String               @id @default(uuid()) @db.Uuid
  slug        String               @unique
  name        String
  description String?
  href        String?
  metadata    String[]             @default([])
  producers   AgriSphereProducer[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model AgriSphereProducer {
  id            String                   @id @default(uuid()) @db.Uuid
  slug          String                   @unique
  name          String
  countryCode   String?
  sectorId      String?                  @db.Uuid
  isTopProducer Boolean                  @default(false)
  producerRank  Int?
  commodities   String[]                 @default([])
  signal        String?
  activityLevel AgriSphereActivityLevel?
  country       AgriSphereCountry?       @relation(fields: [countryCode], references: [code], onDelete: SetNull)
  sector        AgriSphereSector?        @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([countryCode])
  @@index([sectorId])
  @@index([isTopProducer, producerRank])
}

model AgriSphereEvent {
  id          String                @id @default(uuid()) @db.Uuid
  slug        String                @unique
  title       String
  eventType   String
  startsAt    DateTime
  endsAt      DateTime?
  format      AgriSphereEventFormat
  url         String?
  countryCode String?
  metadata    String[]              @default([])
  country     AgriSphereCountry?    @relation(fields: [countryCode], references: [code], onDelete: SetNull)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([countryCode])
  @@index([startsAt])
}

model AgriSpherePartner {
  id        String                @id @default(uuid()) @db.Uuid
  slug      String                @unique
  name      String
  logoUrl   String?
  tier      AgriSpherePartnerTier
  url       String?
  sortOrder Int                   @default(0)
  metadata  String[]              @default([])
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([tier, sortOrder])
}

model AgriSpherePlatformStatsSnapshot {
  id                 BigInt   @id @default(autoincrement())
  countryCount       Int
  farmerCount        Int
  partnerCount       Int
  activeProjectCount Int
  recordedAt         DateTime @default(now())

  @@index([recordedAt])
}

model AgriSphereMapPinClusterReading {
  id         BigInt   @id @default(autoincrement())
  clusterId  String
  rawCount   Int
  recordedAt DateTime @default(now())

  @@index([clusterId, recordedAt])
}
